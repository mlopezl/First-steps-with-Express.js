{
  "info": {
    "name": "Curso Express API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Colección para probar las rutas del proyecto curso-express."
  },
  "variable": [
    {
      "key": "serverUrl",
      "value": "http://localhost:3005"
    },
    {
      "key": "baseUrl",
      "value": "{{serverUrl}}/api"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "adminToken",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Hello World",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{serverUrl}}/",
          "host": [
            "{{serverUrl}}"
          ],
          "path": [
            ""
          ]
        }
      }
    },
    {
      "name": "Register user",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\",\n  \"name\": \"Mi Nombre\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/register",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "register"
          ]
        }
      }
    },
    {
      "name": "Login user",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "login"
          ]
        }
      }
    },
    {
      "name": "Protected route",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/auth/protected-route",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "protected-route"
          ]
        }
      }
    },
    {
      "name": "Create time block (ADMIN)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"startTime\": \"2026-05-10T09:00:00.000Z\",\n  \"endTime\": \"2026-05-10T10:00:00.000Z\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/admin/time-blocks",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "admin",
            "time-blocks"
          ]
        }
      }
    },
    {
      "name": "List reservations (ADMIN)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/admin/reservations",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "admin",
            "reservations"
          ]
        }
      }
    },
    {
      "name": "Create reservation",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"date\": \"2026-05-10T09:00:00.000Z\",\n  \"userId\": 1,\n  \"timeBlockId\": 1\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/reservations",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "reservations"
          ]
        }
      }
    },
    {
      "name": "Get reservation by ID",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/reservations/1",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "reservations",
            "1"
          ]
        }
      }
    },
    {
      "name": "Update reservation",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"date\": \"2026-05-10T10:00:00.000Z\",\n  \"userId\": 1,\n  \"timeBlockId\": 2\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/reservations/1",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "reservations",
            "1"
          ]
        }
      }
    },
    {
      "name": "Delete reservation",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/reservations/1",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "reservations",
            "1"
          ]
        }
      }
    }
  ]
}
